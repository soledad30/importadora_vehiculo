JWT_SECRET=importadora-vehiculos-jwt-secret-key-2026-min-32-chars
DL_WORKER_URL=http://localhost:5000
MS1_API_URL=http://localhost:8080/api/v1

# DynamoDB Local (MS-3 metadatos)
DYNAMODB_ENDPOINT=http://localhost:8000
DYNAMODB_REGION=us-east-1
DYNAMODB_TABLE_DOCUMENTOS=ms3-documentos
DYNAMODB_TABLE_INSPECCIONES=ms3-inspecciones
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# MinIO / S3 (MS-3 archivos)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET=importadora-ms3-docs
S3_REGION=us-east-1
S3_USE_SSL=false

# Modelo YOLO local (requiere plan Roboflow pago para Download Weights)
USE_DL_MODEL=false
DL_DAMAGE_MODEL_PATH=
DL_CONF_THRESHOLD=0.35

# Inferencia Roboflow cloud (opción C — plan gratuito, sin descargar .pt)
# API Key: https://app.roboflow.com/settings/api
ROBOFLOW_API_KEY=
ROBOFLOW_WORKSPACE=soles-workspace
ROBOFLOW_PROJECT=vehicle-damage-detection-nuiry
ROBOFLOW_VERSION=1
