# API del backend (MS-1 directo o vía API Gateway)
# MS-1 directo — emulador Android:
#   EXPO_PUBLIC_API_URL=http://10.0.2.2:8080
# API Gateway (un solo puerto, recomendado si usas Nginx :8888):
#   EXPO_PUBLIC_API_URL=http://10.0.2.2:8888
# Dispositivo físico: http://<IP-LAN-PC>:8080 o :8888
EXPO_PUBLIC_API_URL=http://10.0.2.2:8080
